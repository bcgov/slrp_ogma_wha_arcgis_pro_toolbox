# =============================================================================
# Designated Lands Pipeline - .gitignore
# =============================================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/

# ---------- Esri File Geodatabases ----------
*.gdb/
*xml
*.link

# ---------- Rasters & imagery ----------
rasters/
*.tif
*.tfw
*.tif.ovr
*.tif.aux.xml
*.tif.vat.*
*.tif.xml
*.img
*.adf

# ---------- Pipeline outputs ----------
outputs/
*.xlsx

# ---------- Logs ----------
logs/
*.log

# ---------- Downloaded / extracted source data ----------
source_data/

# ---------- IDE / editor ----------
.vscode/
.idea/

# ---------- Environment / secrets ----------
.env
.venv/
env/
venv/

# ---------- OS junk ----------
Thumbs.db
Desktop.ini
.DS_Store

# ---------- Misc ----------
*.lock
.cache/
.pytest_cache/
